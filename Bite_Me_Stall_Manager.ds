	 			row = 1
	 			column = 1   
				width = medium
			)
			item_name
			(
    			type = text
				displayname = "Item Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			quantity
			(
				type = number
				displayname = "Quantity"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			unit_price
			(
				displayname = "Unit Price"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_price
			(
				displayname = "Total Price"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
