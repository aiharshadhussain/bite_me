 application "Bite Me Stall Manager"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form inventory
		{
			displayname = "Inventory"
			success message = "Inventory Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			item_id
			(
				type = list	
				displayname = "Item ID"
				values  = menu_items.ID
    			displayformat = [item_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			reorder_level
			(
				type = number
				displayname = "Reorder Level"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_updated
			(
    			type = datetime
				displayname = "Last Updated"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			low_stock_alert
			(
    			type = checkbox
				displayname = "Low Stock Alert"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Inventory Record Created","Stock Level Checked","Low Stock Alert Triggered","Stock Level Normal","Restock Request Generated","Inventory Monitoring Active","Restock Request Approved","Restock Request Rejected","Purchase Order Created","Goods Received","Purchase Order On Hold","Purchase Order Cancelled","Inventory Updated","Quality Check Failed","Return to Supplier","Goods Received (Partial)","Low Stock Alert Reset"}
			}
		}
		form menu_items
		{
			displayname = "Menu Items"
			success message = "Menu Item Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			item_id
			(
    			type = autonumber
				displayname = "Item ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			item_name
			(
    			type = text
				displayname = "Item Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			category
			(
				type = picklist
				displayname = "Category"
				values = {"Momo","Paniyaram","Mojito"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			variant
			(
    			type = text
				displayname = "Variant"
	 			row = 1
	 			column = 1   
				width = medium
			)
			price
			(
				displayname = "Price"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			is_active
			(
    			type = checkbox
				displayname = "Is Active"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form order_items
		{
			displayname = "Order Items"
			success message = "Order Item Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
