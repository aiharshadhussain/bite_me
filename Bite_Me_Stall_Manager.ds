	 			column = 1   
				width = medium
			)
			discount_percentage
			(
    			type = percentage
				displayname = "Discount Percentage"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			final_amount
			(
				displayname = "Final Amount"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			payment_method
			(
				type = radiobuttons
				displayname = "Payment Method"
				values = {"Cash","UPi"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			payment_status
			(
				type = radiobuttons
				displayname = "Payment Status"
				values = {"Paid","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			order_status
			(
				type = picklist
				displayname = "Order Status"
				values = {"Ready","Delivered","Preparing"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			created_by
			(
    			type = text
				displayname = "Created By"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Order Placed","Order Confirmed","Order Pending Payment","Order Cancelled","Order Processed","Order Shipped","Order On Hold","Order Delivered","Order Returned","Order Lost","Order Closed","Order Refunded","Order Replacement Shipped"}
			}
		}
