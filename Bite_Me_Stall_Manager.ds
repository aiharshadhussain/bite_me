   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form orders
		{
			displayname = "Orders"
			success message = "Order Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			order_id
			(
    			type = autonumber
				displayname = "Order ID"
				start index = 1
	 			row = 1
