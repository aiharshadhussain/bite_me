	reports
	{
		list order_items_Report
		{
			displayName = "All Order Items"
			show all rows from order_items    
			(
				order as "Order"
				item_name as "Item Name"
				quantity as "Quantity"
				unit_price as "Unit Price"
				(
					display = total,average,min,max	
				)
				total_price as "Total Price"
				(
					display = total,average,min,max	
				)
			)
		}
		list inventory_Report
		{
			displayName = "All Inventories"
			show all rows from inventory    
			(
				item_id as "Item ID"
				reorder_level as "Reorder Level"
				last_updated as "Last Updated"
				low_stock_alert as "Low Stock Alert"
			)
		}
		list menu_items_Report
		{
			displayName = "All Menu Items"
			show all rows from menu_items    
			(
				item_id as "Item ID"
				item_name as "Item Name"
				category as "Category"
				variant as "Variant"
				price as "Price"
				(
					display = total,average,min,max	
				)
				is_active as "Is Active"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (category == "Mojito")
				fields = [category]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (category == "Momo")
				fields = [category]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (category == "Paniyaram")
				fields = [category]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban menu_items_by_category
		{
			displayName = "Categories"
			show all rows from menu_items    
			(
				item_id as "Item ID"
				item_name as "Item Name"
				category as "Category"
				variant as "Variant"
				price as "Price"
				(
					display = total,average,min,max	
				)
				is_active as "Is Active"
			)
			options
			(
	 			display field = category
	 		)
		}
		list orders_Report
		{
			displayName = "All Orders"
			show all rows from orders    
			(
				order_id as "Order ID"
				customer_name as "Customer Name"
				order_date as "Order Date"
				total_amount as "Total Amount"
				(
					display = total,average,min,max	
				)
				discount_percentage as "Discount Percentage"
				(
					display = total,average,min,max	
				)
				final_amount as "Final Amount"
				(
					display = total,average,min,max	
				)
				payment_method as "Payment Method"
				payment_status as "Payment Status"
				order_status as "Order Status"
				created_by as "Created By"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (order_status == "Delivered")
				fields = [order_status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (order_status == "Preparing")
				fields = [order_status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (order_status == "Ready")
				fields = [order_status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban orders_by_order_status
		{
			displayName = "Order Statuses"
			show all rows from orders    
			(
				order_id as "Order ID"
				customer_name as "Customer Name"
				order_date as "Order Date"
				total_amount as "Total Amount"
				(
					display = total,average,min,max	
				)
				discount_percentage as "Discount Percentage"
				(
					display = total,average,min,max	
				)
				final_amount as "Final Amount"
				(
					display = total,average,min,max	
				)
				payment_method as "Payment Method"
				payment_status as "Payment Status"
				order_status as "Order Status"
				created_by as "Created By"
			)
			options
			(
	 			display field = order_status
	 		)
		}
		list sales_dashboard_Report
		{
			displayName = "Sales Dashboard Report"
			show all rows from sales_dashboard    
			(
				date_1 as "Date"
				total_revenue as "Total Revenue"
				(
					display = total,average,min,max	
				)
				top_selling_item as "Top Selling Item"
				cash_payment as "Cash Payment"
				(
					display = total,average,min,max	
				)
				upi_payment as "UPi Payment"
				(
					display = total,average,min,max	
				)
			)
		}
		list user_roles_Report
		{
			displayName = "All User Roles"
			show all rows from user_roles    
			(
				username as "Username"
				role as "Role"
				access_level as "Access Level"
				last_login as "Last Login"
			)
		}
	}
	pages
	{
		page DashBoard
		{
